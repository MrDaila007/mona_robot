# ==============================================================================
# .gitignore
# Purpose: Prevent local build artifacts, temp files, and IDE configurations
#          from being tracked in the MONA repository.
# ==============================================================================

# --- ROS 2 Build Artifacts --- #
build/
install/
log/
test_results/

# --- Python --- #
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
.venv/
*.egg-info/

# --- C++ --- #
*.obj
*.o
*.a
*.so
*.dylib

# --- 3D CAD --- #
# FreeCAD temporary backups
*.FCBak

# --- IDEs & Editors --- #
# Obsidian knowledge base
.obsidian/
.trash/

# VS Code
.vscode/
# Uncomment the lines below to share specific launch settings:
# !.vscode/launch.json
# !.vscode/tasks.json

# JetBrains (CLion, PyCharm)
.idea/
cmake-build-*/

# Vim / Emacs / Sublime / OS-specific
*~
*.swp
*.swo
.DS_Store

# --- Generated Documentation --- #
docs/_build/

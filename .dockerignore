# ==============================================================================
# .dockerignore
# Purpose: Exclude unnecessary files from the Docker build context to reduce
#          image size and prevent cache invalidation.
# ==============================================================================

# --- Build Artifacts --- #
build/
install/
log/
test_results/

# --- Version Control --- #
.git/
.gitignore
.github/

# --- IDE & Editor Settings --- #
.vscode/
.idea/
.obsidian/

# --- Documentation & CI/CD --- #
docs/
Dockerfile
docker-compose*.yml
Makefile
README.md
SECURITY.md
CONTRIBUTING.md
LICENSE
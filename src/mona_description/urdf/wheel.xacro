<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="wheel_radius" value="0.127"/>
    <xacro:property name="wheel_width"  value="0.10"/>
    <xacro:property name="wheel_weight" value="15.0"/>

    <xacro:macro name="mecanum_wheel" params="name x y flip_visual parent height_offset">
        
        <link name="${name}_link">
            <visual>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/> 
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
                </geometry>
                <material name="black">
                    <color rgba="0.1 0.1 0.1 1.0"/>
                </material>
            </visual>
            
            <collision>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
                </geometry>
            </collision>
            
            <inertial>
                <mass value="${wheel_weight}"/>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                <inertia ixx="${(1.0/12.0) * wheel_weight * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}" ixy="0" ixz="0"
                         iyy="${(1.0/12.0) * wheel_weight * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}" iyz="0"
                         izz="${(1.0/2.0) * wheel_weight * wheel_radius*wheel_radius}"/>
            </inertial>
        </link>

        <joint name="${name}_joint" type="continuous">
            <parent link="${parent}"/>
            <child link="${name}_link"/>
            <origin xyz="${x} ${y} ${height_offset}" rpy="0 0 0"/>
            <axis xyz="0 1 0"/>
        </joint>

        <gazebo reference="${name}_link">
            <material>Gazebo/Grey</material>
            <mu1>0.8</mu1> 
            <mu2>0.8</mu2>
        </gazebo>
    </xacro:macro>

</robot>